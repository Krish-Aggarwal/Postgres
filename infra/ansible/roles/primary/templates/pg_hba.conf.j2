# TYPE  DATABASE        USER                ADDRESS           METHOD

# Local connections
local   all             postgres                              peer
local   all             all                                   md5

# IPv4 local
host    all             all                 127.0.0.1/32      md5

# IPv6 local
host    all             all                 ::1/128           md5

# Allow all VPC connections
host    all             all                 10.0.0.0/16       md5

# Replication from sync standby AZ-b (private subnet 10.0.12.0/24)
host    replication     {{ replication_user }}   10.0.12.0/24    md5

# Replication from async standby AZ-c (private subnet 10.0.13.0/24)
host    replication     {{ replication_user }}   10.0.13.0/24    md5
